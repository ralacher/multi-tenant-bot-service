# Microsoft 365 Agents SDK / Azure Bot auth
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=MultiTenant
MICROSOFT_APP_TENANT_ID=
# For cross-tenant use (Tenant A users, Tenant B hosting), keep MultiTenant and set Tenant B app tenant ID.

# Direct MSAL connection settings used by runtime auth
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=ClientSecret
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SCOPES=https://api.botframework.com/.default
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHORITY=https://login.microsoftonline.com/<YOUR_TENANT_ID>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=

# App runtime
PORT=3978

# Foundry existing agent connection
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.4
FOUNDRY_AGENT_NAME=
FOUNDRY_AGENT_ID=

# Optional bootstrap inputs for scripts/bootstrap_foundry_agent.py
# Reuses FOUNDRY_AGENT_NAME above. Set it to mta-prompt-agent (or your preferred name) for bootstrap.
FOUNDRY_AGENT_INSTRUCTIONS=
FOUNDRY_KNOWLEDGE_FILE=

# Optional observability
APPLICATIONINSIGHTS_CONNECTION_STRING=
